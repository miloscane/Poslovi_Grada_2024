<%- include ("partials/header") -%>
	<script>
		var proizvodi	=	<%-JSON.stringify(proizvodi)%>;
		var reversi		=	<%-JSON.stringify(reversi)%>;
		var izdatMaterijal = [];
		for(var i=0;i<reversi.length;i++){
			for(var j=0;j<reversi[i].zaduzenje.length;j++){
				reversi[i].zaduzenje[j].naziv = getProizvodByCode(reversi[i].zaduzenje[j].uniqueId).name;
				reversi[i].zaduzenje[j].jedinicaMere = getProizvodByCode(reversi[i].zaduzenje[j].uniqueId).unit;
				var materijalIndex = -1;
				for(var k=0;k<izdatMaterijal.length;k++){
					if(izdatMaterijal[k].uniqueId==reversi[i].zaduzenje[j].uniqueId){
						materijalIndex = k;
						break;
					}
				}
				if(materijalIndex==-1){
					var json = {};
					json.uniqueId = reversi[i].zaduzenje[j].uniqueId;
					json.name = reversi[i].zaduzenje[j].naziv;
					json.unit = reversi[i].zaduzenje[j].jedinicaMere;
					json.quantity = parseFloat(reversi[i].zaduzenje[j].quantity)-parseFloat(reversi[i].zaduzenje[j].quantity2);
					izdatMaterijal.push(json);
				}else{
					izdatMaterijal[k].quantity = izdatMaterijal[k].quantity + parseFloat(reversi[i].zaduzenje[j].quantity)-parseFloat(reversi[i].zaduzenje[j].quantity2);
				}
			}
			
			
		}
	</script>
	<div class="magacinStanje magacinRevers cuprijaLista">
		<div class="pageWidth">
			<div class="table">
				<table id="table">
					<tr>
						<td class="naziv">Naziv</td>
						<td class="kolicina">Kolicina</td>
						<td class="jedinica">Jedinica mere</td>
					</tr>
				</table>
				<script>
					for(var i=0;i<izdatMaterijal.length;i++){
						var tr = document.createElement("TR");
							var td = document.createElement("TD");
							td.setAttribute("class","naziv");
							td.innerHTML = izdatMaterijal[i].name;
							tr.appendChild(td);

							var td = document.createElement("TD");
							td.setAttribute("class","kolicina");
							td.innerHTML = izdatMaterijal[i].quantity.toFixed(2);
							tr.appendChild(td);

							var td = document.createElement("TD");
							td.setAttribute("class","jedinica");
							td.innerHTML = izdatMaterijal[i].unit;
							tr.appendChild(td);
						document.getElementById("table").appendChild(tr);
					}
				</script>
				<div class="inputWrap" style="margin-top:50px">
					<div class="button" onclick="printTable()">STAMPAJ</div>
				</div>
				<%- include ("partials/printer") -%>
				<div style="overflow:hidden;height:1px;width:1px;">
					<canvas id="logo-canvas" height="306" width="300"></canvas>
					<script>
						var logoCanvas = document.getElementById('logo-canvas');
						var logoCanvasContext = logoCanvas.getContext('2d');
						var logoLogoBlob;
						function make_base3(){
						  base_image3 = new Image();
						  base_image3.crossOrigin="anonymous"
						  //base_image3.src = 'https://poslovi-grada-2024.fra1.digitaloceanspaces.com/images/fakturaLogo.png';
						  base_image3.src = '/images/fakturaLogo.png';
						  base_image3.onload = function(){
						    logoCanvasContext.drawImage(base_image3, 0, 0);
						    logoLogoBlob 	=	logoCanvas.toDataURL("image/png", 1.0);

						  }
						}
						make_base3();
					</script>
				</div>
				<script>

					function splitInto40(str) {
					    var result = [];
					    for (var i = 0; i < str.length; i += 40) {
					        result.push(str.substring(i, i + 40));
					    }
					    return result;
					}

					function printTable(){
						doc = new jsPDF({
							orientation: 'p',
							unit: 'mm',
							format: 'a4',
							compress: true
							//putOnlyUsedFonts:true
						});
						pageHeight = doc.internal.pageSize.height || doc.internal.pageSize.getHeight();
						pageWidth = doc.internal.pageSize.width || doc.internal.pageSize.getWidth();
						var yPos = 40;
						var xPos = 12;
						//doc.getFontList("Helvetica");
						doc.addFileToVFS("PTSans.ttf", PTSans);
						doc.addFileToVFS("PTSansBold.ttf", PTSansBold);
						doc.addFont('PTSans.ttf', 'PTSans', 'normal');
						doc.addFont('PTSansBold.ttf', 'PTSans', 'bold');

						doc.setFont('PTSans'); // set font
						doc.getFontList("PTSans");
						if(logoLogoBlob ){
							doc.addImage(logoLogoBlob , 'PNG', 5, 5, 119/mm, 119/mm,'','FAST');
						}

				        doc.setFontType("bold");
						doc.setFontSize(20);
				        doc.text("Izdat materijal za datum "+getDateAsStringForDisplay(new Date()),pageWidth/2,yPos,'center');
				        yPos = yPos + 10;
				        doc.setFontType("normal");
						doc.setFontSize(16);
						yPos = yPos + 10;
						
						doc.text("Ћуприја",pageWidth/2,yPos,'center');
						yPos = yPos + 10;
						yPos = yPos + 10;
				        doc.setFontType("bold");
						doc.text("Mатеријал:",5,yPos);
						doc.text("Издато:",150,yPos);
						//doc.text("Раздужено:",180,yPos);
						doc.setFontType("normal");
						doc.setFontSize(14);
						yPos = yPos + 7;
						for(var i=0;i<izdatMaterijal.length;i++){
				        	doc.setFontType("bold");
							doc.text(eval(i+1).toString()+".",5,yPos);
							doc.setFontType("normal");
							var proizvodNaziv = splitInto40(izdatMaterijal[i].name);
							doc.text(izdatMaterijal[i].quantity.toFixed(2)+" "+izdatMaterijal[i].unit,150,yPos);
							//doc.text(revers.zaduzenje[i].quantity2+" kom.",150,yPos);
							//doc.text("_____ "+getProductById(revers.zaduzenje[i].uniqueId).unit,150,yPos);
							//doc.text("_____ "+getProductById(revers.zaduzenje[i].uniqueId).unit,180,yPos);
							for(var j=0;j<proizvodNaziv.length;j++){
								doc.text(proizvodNaziv[j],15,yPos);
								yPos = yPos + 7;
							}
							
							//yPos = yPos + 7;
							if(yPos>285){
								doc.addPage()
								yPos = 5;
							}
						}
						yPos = yPos + 7;
						if(yPos>285){
							doc.addPage()
							yPos = 5;
						}
						doc.setFontType("bold");
						doc.text("Potpis magacionera",5,yPos);
						yPos = yPos + 15;
						if(yPos>285){
							doc.addPage()
							yPos = 5;
						}
						doc.setDrawColor(0);
				        doc.setFillColor(0,0,0);
						doc.rect(5, yPos, 50, 0.4, 'F');

						
				        window.open(doc.output('bloburl'), '_blank');
					}
				</script>
			</div>		
		</div>
	</div>
<%- include ("partials/footer") -%>
