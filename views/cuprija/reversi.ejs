<%- include ("partials/header") -%>
	<script>
		var reversi = <%-JSON.stringify(reversi)%>;
	</script>
	<div class="pageWidth">
		<div class="rezultatPretrageReversa">
			<div id="table"></div>
			<script>
				var table = document.createElement("TABLE");
				for(var i=0;i<reversi.length;i++){
					var tr = document.createElement("TR");
						var td = document.createElement("TD");
						td.innerHTML = "<div class=\"value\">"+eval(i+1)+".</div>";
						tr.appendChild(td);

						var td = document.createElement("TD");
						td.innerHTML = "<div class=\"value\">"+reversi[i].brojReversa+"</div>";
						tr.appendChild(td);

						var reversDate = new Date(Number(reversi[i].datetime));
						var td = document.createElement("TD");
						td.innerHTML = "<div class=\"value\">"+reversi[i].datum+" "+reversDate.getHours().toString().padStart(2,'0')+":"+reversDate.getMinutes().toString().padStart(2,'0')+"</div>";
						tr.appendChild(td);

						var td = document.createElement("TD");
						var majstor = reversi[i].majstor;
						td.innerHTML = "<div class=\"value\">"+majstor+"</div>";
						tr.appendChild(td);

						var td = document.createElement("TD");
						td.innerHTML = "<div class=\"value\"><a href=\"/cuprija/revers/"+reversi[i].uniqueId+"\" target=\"_blank\">Види реверс</div>";
						tr.appendChild(td);

					table.appendChild(tr);
					var redniBroj = document.cr
				}
				document.getElementById("table").appendChild(table);

			</script>
		</div>
	</div>
<%- include ("partials/footer") -%>
