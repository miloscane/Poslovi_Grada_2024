<%- include ("partials/header") -%>

	<script>
		var majstori = <%-JSON.stringify(majstori)%>;
		var pomocnici = <%-JSON.stringify(pomocnici)%>;
		var users = <%-JSON.stringify(users)%>;
		var datum = "<%=datum%>";
		majstori.sort((a, b) => a.ime.localeCompare(b.ime));
		pomocnici.sort((a, b) => a.ime.localeCompare(b.ime));
		users.sort((a, b) => a.ime.localeCompare(b.ime));
		var checkIns = <%-JSON.stringify(checkIns)%>;
		checkIns.sort((a, b) => Number(a.datetime) - Number(b.datetime));

		function formatTime(date) {
			return date.getHours().toString().padStart(2, "0") + ":" +
				   date.getMinutes().toString().padStart(2, "0");
		}

		function addCheckInData(list, checkIns) {
			list.forEach(user => {
				user.vremeDolaska = "/";
				user.vremeDolaskaUser = false;
				user.vremeOdlaska = "/";
				user.vremeOdlaskaUser = false;
				user.radnoVreme = "/";
				user.checkIns = checkIns.filter(checkIn => checkIn.uniqueId == user.uniqueId);

				if (user.checkIns.length > 1) {
					const prviCheckIn = user.checkIns[0];
					const zadnjiCheckIn = user.checkIns[user.checkIns.length - 1];

					const vremeDolaska = new Date(Number(prviCheckIn.datetime));
					const vremeOdlaska = new Date(Number(zadnjiCheckIn.datetime));

					const totalMiliseconds = vremeOdlaska.getTime() - vremeDolaska.getTime();

					user.vremeDolaska = formatTime(vremeDolaska);

					if (prviCheckIn.checkInUser) {
						user.vremeDolaskaUser = prviCheckIn.checkInUser;
					}

					// Ako je razlika manja od 1 sat, ne prikazuj vreme odlaska
					if (totalMiliseconds < 60 * 60 * 1000) {
						user.vremeOdlaska = "/";
						user.vremeOdlaskaUser = false;
						user.radnoVreme = "/";
						return;
					}

					user.vremeOdlaska = formatTime(vremeOdlaska);

					if (zadnjiCheckIn.checkInUser) {
						user.vremeOdlaskaUser = zadnjiCheckIn.checkInUser;
					}

					const totalMinutes = Math.floor(totalMiliseconds / 60000);
					const hours = Math.floor(totalMinutes / 60);
					const minutes = totalMinutes % 60;

					user.radnoVreme = String(hours).padStart(2, "0") + ":" + String(minutes).padStart(2, "0");

				} else if (user.checkIns.length == 1) {
					const vreme = new Date(Number(user.checkIns[0].datetime));

					if (vreme.getHours() < 14) {
						user.vremeDolaska = formatTime(vreme);
					} else {
						user.vremeOdlaska = formatTime(vreme);
					}
				}
			});
		}

		addCheckInData(majstori, checkIns);
		addCheckInData(pomocnici, checkIns);
		addCheckInData(users, checkIns);

		function getPomocnikByCard(card){
		  var pomocnik = {};
		  if(pomocnici){
		    for(var i=0;i<pomocnici.length;i++){
		      if(pomocnici[i].brojKartice.toString()==card.toString()){
		        pomocnik = pomocnici[i];
		        break;
		      }
		    }
		    if(!pomocnik.ime){
		      pomocnik.ime = "Нема";
		    }
		  }else{
		    //console.log("No array majstori defined");
		  }
		  return pomocnik
		}
