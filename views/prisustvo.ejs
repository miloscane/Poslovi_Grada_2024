	   					var minutes = totalMinutes % 60;
	   					administracijaElems[i].getElementsByClassName("totalHours")[0].innerHTML = "Сатница: "+String(hours).padStart(2, '0') + ":" + String(minutes).padStart(2, '0')
					}
					
