					jucerasnjiDatum.setDate(jucerasnjiDatum.getDate() - 1);
					
					for(var i=0;i<obracunatiNalozi.length;i++){
						var nalog = obracunatiNalozi[i]
						if(istiDatum(new Date(nalog.datum.punDatum),danasnjiDatum)){
							danasNaloga++;
						}
						if(istiDatum(new Date(nalog.datum.punDatum),jucerasnjiDatum )){
							juceNaloga++;
						}
					}
					
					for(var i=0;i<nalozi.length;i++){
						var nalog = nalozi[i];
