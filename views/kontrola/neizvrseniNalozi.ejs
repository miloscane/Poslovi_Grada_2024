							danasNaloga++;
						}
						if(istiDatum(new Date(nalog.datum.punDatum),jucerasnjiDatum )){
							juceNaloga++;
						}
					}
					document.getElementById("danas-naloga").innerHTML = danasNaloga;
					document.getElementById("juce-naloga").innerHTML = juceNaloga;
